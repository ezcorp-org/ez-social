# Database — local Docker PostgreSQL
DATABASE_URL=postgresql://ezsocial:ezsocial@localhost:5433/ezsocial

# Auth.js
AUTH_SECRET=change-me-to-random-secret
AUTH_TRUST_HOST=true

# Anthropic (AI voice extraction)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Set to "true" to use mock AI responses (for E2E tests, no API calls)
# MOCK_AI=true
